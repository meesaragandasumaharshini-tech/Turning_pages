<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Turning Pages</title>

    <link rel="stylesheet" href="/styles/main.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
</head>

<body>

<header>

    <div class="title">
        <h1>Turning Pages</h1>
    </div>

    <div>
        <a href="/books" class="btn">All Books</a>
    </div>

</header>


<section class="search-section">

    <form action="/" method="GET" class="search-form">

        <input
            type="text"
            name="search"
            placeholder="Search here..."
        >

        <select name="sort" onchange="this.form.submit()">

            <option value="">Sort By</option>
            <option value="title">A-Z</option>
            <option value="rating">Rating</option>

        </select>

    </form>

</section>



<section class="hero">

    <h1>
        Hi, I'm Suma Harshini
    </h1>

    <p>
        Reading has always been one of my favorite ways to relax, learn, and explore new worlds. This website is my little corner of the internet where I keep track of the books I've read and share my thoughts about each one.
    </p>

    <p>
        From magical adventures and timeless mythology to inspiring non-fiction and thought-provoking stories, every review here reflects my personal reading experience. Feel free to browse the collection, check out my ratings, and maybe find your next favorite book. Happy reading! ✨
    </p>

</section>



<section class="latest">

    <h2>Latest Read Books</h2>

    <div class="latest-books">

        <% latestBooks.forEach(book => { %>

    <div class="book-card">

        <img src="https://covers.openlibrary.org/b/olid/<%= book.cover_id %>.jpg" alt="<%= book.title %>">

        <h3><%= book.title %></h3>

        <p><%= book.author %></p>

        <p>⭐ <%= book.rating %>/5</p>

        <button type="button" onclick="toggleNotes(<%= book.id %>)">
            View Notes
        </button>

        <div id="notes-<%= book.id %>" class="notes-box" style="display: none;">
            <p><%= book.notes %></p>
        </div>

    </div>

<% }) %>
    </div>

</section>



<section class="all-books-button">

    <a href="/books" class="btn">
        All Books
    </a>

</section>

<footer>
    <p>Copyright © <%=  new Date().getFullYear() %> Turning Pages — Suma Harshini</p>
    <div class="social-links">
        <a href="https://www.linkedin.com/in/suma-harshini-meesaraganda-b527b7293/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://www.instagram.com/suma._m_/" target="_blank" rel="noopener noreferrer">Instagram</a>
    </div>
</footer>
<script>
    function toggleNotes(id) {
        const box = document.getElementById(`notes-${id}`);
        const isHidden = box.style.display === "none";
        box.style.display = isHidden ? "block" : "none";
    }
</script>

</body>
</html>